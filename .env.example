# ══════════════════════════════════════════════════════════════════════════════
# Log Ingestion Platform — Environment Configuration Template
# Copy this file to .env and fill in your values before running.
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Root password for the MongoDB admin user — use a strong random string
MONGO_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── API Authentication ────────────────────────────────────────────────────────
# Shared API key for all devices posting to /ingest/batch
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=CHANGE_ME_API_KEY

# ── Per-Device Rate Limits (logs per minute) ──────────────────────────────────
RATE_LIMIT_PER_DEVICE=5000

# ── Backpressure (max Redis queue depth before 429) ───────────────────────────
QUEUE_BACKPRESSURE_LIMIT=50000

# ── Admin Endpoint Protection ─────────────────────────────────────────────────
# Token for /admin/* endpoints
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=CHANGE_ME_ADMIN_TOKEN

# ── Dashboard Read Access ─────────────────────────────────────────────────────
# Token entered in the browser dashboard login screen
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_TOKEN=CHANGE_ME_DASHBOARD_TOKEN

# ── SMTP Email Alerts (optional — leave SMTP_HOST blank to disable) ───────────
# Sends an alert email when DLQ depth exceeds ALERT_DLQ_THRESHOLD
#
# Common SMTP hosts:
#   Office 365 : smtp.office365.com  port 587
#   Gmail      : smtp.gmail.com      port 587
#   Self-hosted: mail.yourcompany.com port 587
#
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=alerts@yourcompany.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
ALERT_EMAIL_TO=admin@yourcompany.com
ALERT_DLQ_THRESHOLD=10
