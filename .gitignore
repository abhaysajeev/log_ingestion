# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/

# ── Environment / Secrets ─────────────────────────────────
.env
# Do NOT commit .env — use .env.example as a template

# ── SSL Certificates ──────────────────────────────────────
nginx/certs/*.pem
nginx/certs/*.key
nginx/certs/*.crt
nginx/certs/*.csr

# ── Backups ───────────────────────────────────────────────
/backups/

# ── Docker volumes (if mounted locally) ───────────────────
mongo_data/
redis_data/

# ── Logs ──────────────────────────────────────────────────
*.log
/var/log/

# ── Editor / OS ───────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
Thumbs.db
